# Slack transport + Mesh on-chain settlement.
# Copy to .env.slack and fill; do NOT commit the filled version.
# The Rapid Agent .env.rapid-agent variables are STILL required — this
# file only adds the Slack + Mesh keys on top.

# ── Slack app credentials ────────────────────────────────────────
# From api.slack.com/apps → your app:
#   Bot token:      OAuth & Permissions → Bot User OAuth Token (xoxb-...)
#   Signing secret: Basic Information → App Credentials → Signing Secret
SLACK_BOT_TOKEN=xoxb-REPLACE
SLACK_SIGNING_SECRET=REPLACE

# ── Mesh on-chain settlement (for /kajota pay) ───────────────────
# Default chain is mantle-sepolia — the only Mesh deployment with the
# full stack (Registry + Escrow + MockUSDC) live. Override to `amoy` or
# `sepolia` if you deploy the escrow to those chains later.
MESH_CHAIN=mantle-sepolia

# Optional per-address overrides — leave unset to use the defaults
# baked into kajota_concierge.mesh.DEFAULT_CHAINS.
# MESH_RPC_URL=https://rpc.sepolia.mantle.xyz
# MESH_COSELL_REGISTRY=0x33A1029d5E43E0A4eb1E9397881390D28f02DA7e
# MESH_COSELL_ESCROW=0xe02b16c439e7596F7A032ACe5E9ff42c2ecd3167
# MESH_USDC=0x6F0EaF790309e05C550bD7bbdB36ADF6db978f4d

# Relayer wallet for the demo — if UNSET, /kajota pay returns an
# unsigned tx pair; the Slack user has to sign in their own wallet. If
# SET, the server signs + broadcasts both transactions from this wallet
# so the Slack demo shows a real settlement receipt. Use a throwaway
# key funded from the Mantle Sepolia faucet — never a mainnet key.
# MESH_RELAYER_PRIVATE_KEY=0x...
