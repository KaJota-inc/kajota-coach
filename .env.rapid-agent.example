# KaJota Coach — Google Cloud Rapid Agent hackathon (Jun 11, 2026 2:00 PM PT) env.
#
# Copy to `.env.rapid-agent` (gitignored) before running the agent
# runtime. Pairs with HACKS.md → "Google Cloud Rapid Agent" for the
# credential-mint walkthrough (gcloud commands, partner MCP setup).
#
# Prompt confirmed Jun 8, 2026: requires Gemini 3 + Google Cloud
# Agent Development Kit (ADK) + Model Context Protocol (MCP) + one
# partner integration via MCP (Arize/Elastic/Fivetran/GitLab/MongoDB).
#
# Reference docs:
#   - ADK:  https://docs.cloud.google.com/gemini-enterprise-agent-platform/build/adk
#   - MCP:  https://google.github.io/adk-docs/mcp/

# ---- GCP project --------------------------------------------------

# Project id you created for this hack. Match `gcloud config get-value project`.
GCP_PROJECT_ID=

# Region for Vertex AI / Gemini calls.
GCP_REGION=us-central1

# Service-account JSON path. Pin to the gitignored slot under
# secrets/rapid-agent/ so the file never leaks into the tree. The
# Google SDK reads this from the standard GOOGLE_APPLICATION_CREDENTIALS
# env var.
GOOGLE_APPLICATION_CREDENTIALS=./secrets/rapid-agent/gcp-service-account.json

# ---- Gemini 3 model ----------------------------------------------

# REQUIRED model per the prompt — Gemini 3 Pro (NOT 2.5 Pro/Flash).
GEMINI_MODEL=gemini-3-pro

# Optional fallback / cheaper variant for dev iterations.
GEMINI_FALLBACK_MODEL=gemini-3-flash

# ---- Agent Development Kit (ADK) ----------------------------------

# Agent name as registered in the Gemini Enterprise Agent Platform.
# Set after you deploy via `agents create`.
ADK_AGENT_NAME=

# ADK runtime endpoint — leave blank for local dev (ADK has a built-in
# dev server); fill once you deploy to GEAP Agent Runtime.
ADK_RUNTIME_URL=

# ---- MCP partner integration --------------------------------------

# REQUIRED: pick ONE partner per the prompt. Recommended: MongoDB
# (coach already has session state that fits a query interface).
# Others: arize / elastic / fivetran / gitlab.
PARTNER=mongodb

# Partner-specific config. Uncomment the section for your chosen
# partner; leave the rest empty.

# ---- MongoDB (recommended for coach) ----
MONGODB_URI=
MONGODB_DATABASE=
# MongoDB-hosted MCP server endpoint (Atlas or self-hosted).
MONGODB_MCP_URL=

# ---- Elastic ----
# ELASTIC_CLOUD_ID=
# ELASTIC_API_KEY=
# ELASTIC_MCP_URL=

# ---- Arize AI (observability) ----
# ARIZE_API_KEY=
# ARIZE_SPACE_KEY=
# ARIZE_MCP_URL=

# ---- Fivetran ----
# FIVETRAN_API_KEY=
# FIVETRAN_MCP_URL=

# ---- GitLab ----
# GITLAB_TOKEN=
# GITLAB_MCP_URL=

# ---- Coach runtime ------------------------------------------------

# Coach backend URL (kajota-mobile-backend `hackathon/coach-agent-v2`
# branch). Used by the agent to read user policy + log decisions.
COACH_BACKEND_URL=

# ---- Hackathon judging hooks --------------------------------------

# Submission deliverables (record after each step lands):
#   Devpost submission URL:
#   Public repo URL:
#   Demo video URL:
