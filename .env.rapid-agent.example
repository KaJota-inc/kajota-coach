# KaJota Coach — Google Cloud Rapid Agent hackathon (Jun 11, 2026) env.
#
# Copy to `.env.rapid-agent` (gitignored) before running the coach
# agent flow against Vertex AI / Gemini. Pairs with HACKS.md →
# "Rapid Agent" for the full credential-mint checklist (gcloud
# commands, IAM roles, etc.).

# ---- GCP project --------------------------------------------------

# Project id you created for this hack. Match the gcloud project
# config (`gcloud config get-value project`).
GCP_PROJECT_ID=

# Region for Vertex AI calls.
GCP_REGION=us-central1

# Service-account JSON path. Pin to the gitignored slot under
# secrets/rapid-agent/ so the file never leaks into the tree. The
# Google SDK reads this from the standard env var.
GOOGLE_APPLICATION_CREDENTIALS=./secrets/rapid-agent/gcp-service-account.json

# ---- Vertex AI model ---------------------------------------------

# Default model for the agent runtime — Gemini 2.5 Pro / Flash etc.
# Confirm the exact id in the Rapid Agent track prompt.
VERTEX_MODEL=gemini-2.5-pro

# ---- Coach runtime ------------------------------------------------

# Coach backend URL (kajota-mobile-backend `hackathon/coach-agent-v2`
# branch). Used by the agent to read user policy + log decisions.
COACH_BACKEND_URL=

# ---- Rapid-Agent-specific config ----------------------------------

# TODO(rapid-agent): pin Rapid Agent track-specific config once the
# prize prompt publishes (judge endpoint, evaluator schema, scoring
# webhook, etc.).
RAPID_AGENT_TODO=
