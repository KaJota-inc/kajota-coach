# ─────────────────────────────────────────────────────────────────────────
# KaJota Coach × Casper — environment template
# Copy to `agent/.env.casper` and fill in. The agent loads `.env` /
# `.env.rapid-agent`; source this too (e.g. `set -a; . .env.casper; set +a`)
# or merge these keys into your existing env file.
# ─────────────────────────────────────────────────────────────────────────

# ─── x402 paywall (POST /coach/premium) ──────────────────────────────────
# The premium endpoint settles a CEP-18 micropayment on Casper through the
# CSPR.cloud x402 Facilitator. Without these the endpoint still returns 402,
# but explains it is unconfigured instead of charging.

# Facilitator base URL. Default works; same host serves mainnet + testnet.
X402_FACILITATOR_URL=https://x402-facilitator.cspr.cloud

# CAIP-2 network: casper:casper-test (testnet, default) or casper:casper.
X402_NETWORK=casper:casper-test

# Merchant account/purse that receives the payment — your Casper account hash.
# Create one with Casper Wallet, then fund it with test CSPR from the faucet:
#   https://testnet.cspr.live/tools/faucet  (5,000 test CSPR, one-time)
X402_PAY_TO=

# CEP-18 token contract PACKAGE hash used for payment. Casper's own x402
# reference servers settle in WCSPR (wrapped CSPR, 9 decimals). Get the EXACT
# hash the facilitator accepts from its /supported endpoint once your key is
# set:  python scripts/x402_demo.py --supported
X402_ASSET=

# Price in ATOMIC units of the asset. WCSPR has 9 decimals, so
# 1000000 = 0.001 WCSPR — the canonical "$0.001" micropayment.
X402_MAX_AMOUNT=1000000

# Optional EIP-712 domain hints for the CEP-18 token, as JSON. Helps wallets
# render the charge. For WCSPR: {"name":"WCSPR","symbol":"WCSPR","version":"1","decimals":9}
X402_ASSET_EXTRA=

# Sponsored CSPR.cloud key — the buildathon issues one that unlocks the
# facilitator AND CSPR.cloud. Either name works; CSPR_CLOUD_API_KEY below is
# also accepted as a fallback.
X402_FACILITATOR_API_KEY=

# ─── Casper MCP toolset (agent on-chain awareness) ───────────────────────
# Adds msanlisavas/casper-mcp as a third MCP partner so the agent can read
# Casper on-chain state (balances, deploys, transfers, contracts). Runs the
# .NET MCP server via `docker run -i`, so it needs Docker on the host —
# great locally for the demo, off by default for the Render Python image.

# Set to 1/true to enable. Requires Docker + CSPR_CLOUD_API_KEY.
CASPER_MCP_ENABLED=0

# mainnet (default) or testnet — match X402_NETWORK for a coherent demo.
CASPER_MCP_NETWORK=testnet

# CSPR.cloud API key for the MCP server (and x402 fallback). Same sponsored
# key as above.
CSPR_CLOUD_API_KEY=
