# KaJota Coach — Mantle Turing Test hackathon (Jun 15, 2026 15:59) env.
#
# Copy to `.env.mantle-turing` (gitignored) before running the coach
# agent flow against Mantle Sepolia. Pairs with HACKS.md →
# "Mantle Turing Test 2026" for the credential-mint walkthrough.
#
# Prompt confirmed Jun 8, 2026: requires AI agent on OpenClaw with
# ERC-8004 identity on Mantle testnet. $120k prize pool.
#
# Reference docs:
#   - OpenClaw:      https://docs.openclaw.ai
#   - Mantle DevHub: https://devhub.mantle.xyz
#   - DoraHacks:     https://dorahacks.io/hackathon/mantleturingtesthackathon2026

# ---- Coach runtime (existing) ------------------------------------

# Base URL of the coach backend (kajota-mobile-backend's matching
# `hackathon/coach-agent-v2` branch). Local dev = http://localhost:8080;
# Render-hosted hack URL once deployed.
COACH_BACKEND_URL=

# Coach agent v2 API base — the LangChain/Functions endpoint the
# mobile app hits.
COACH_AGENT_BASE=

# ---- LLM provider (unchanged — OpenClaw wraps, doesn't replace) -

# OpenAI / Anthropic key used by the agent's reasoning loop. The hack
# is stack-additive: OpenClaw provides on-chain identity + reputation,
# but the LLM intelligence layer stays exactly as today's coach.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ---- Mantle Sepolia (Turing Test target chain) --------------------

# Mantle Sepolia RPC. Public endpoint rate-limits hard on dev loops —
# swap in a managed RPC (Alchemy / QuickNode) before the demo loop.
MANTLE_SEPOLIA_RPC=https://rpc.sepolia.mantle.xyz

# Deployer / agent signer EOA, hex 0x-prefixed. Fund via
# https://faucet.sepolia.mantle.xyz. This signer mints the agent's
# ERC-8004 identity NFT and signs reputation-registry feedback.
DEPLOYER_PRIVATE_KEY=0x...

# ---- Mantle integration -------------------------------------------

# Mantlescan API key — https://explorer.sepolia.mantle.xyz/api-keys
# Used for contract verification on deploy.
MANTLESCAN_API_KEY=

# ---- OpenClaw framework -------------------------------------------

# Register the coach as an OpenClaw agent. After registration:
#   - OPENCLAW_AGENT_ID:    the OpenClaw agent identifier
#   - OPENCLAW_GATEWAY_URL: OpenClaw Gateway endpoint (Cloud or
#                          self-hosted per docs.openclaw.ai)
OPENCLAW_AGENT_ID=
OPENCLAW_GATEWAY_URL=

# ---- ERC-8004 contracts (Mantle Sepolia deployed addresses) ------

# Pull the canonical deploys from Mantle DevHub once published;
# otherwise deploy the open-source ERC-8004 reference suite to
# Mantle Sepolia and pin the addresses here.

# Identity Registry — ERC-721 agent identity NFTs (the coach's
# on-chain identity).
ERC8004_IDENTITY_REGISTRY=

# Reputation Registry — signed feedback entries logged per agent
# action.
ERC8004_REPUTATION_REGISTRY=

# Validation Registry — optional, only used if we add zkML / TEE /
# staker proofs to the demo flow.
ERC8004_VALIDATION_REGISTRY=

# Token id of the coach's minted ERC-8004 identity NFT. Set after
# the first successful mint.
COACH_AGENT_TOKEN_ID=

# ---- Hackathon judging hooks --------------------------------------

# Submission deliverables (record after each step lands):
#   X thread URL (#MantleAIHackathon):
#   GitHub repo URL:
#   Demo video URL:
#   Mantle Sepolia contract address (coach agent identity):
