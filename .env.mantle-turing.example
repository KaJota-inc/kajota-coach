# KaJota Coach — Mantle Turing Test hackathon (Jun 15, 2026) env.
#
# Copy to `.env.mantle-turing` (gitignored) before running the coach
# agent flow against Mantle Sepolia. Pairs with HACKS.md →
# "Mantle Turing Test" for the credential-mint checklist.

# ---- Coach runtime ------------------------------------------------

# Base URL of the coach backend (kajota-mobile-backend's matching
# `hackathon/coach-agent-v2` branch). Local dev = http://localhost:8080;
# Render-hosted hack URL once deployed.
COACH_BACKEND_URL=

# Coach agent v2 API base — the LangChain/Functions endpoint the
# mobile app hits.
COACH_AGENT_BASE=

# ---- LLM provider -------------------------------------------------

# OpenAI / Anthropic key used by the agent. Provision a separate key
# from prod so hack usage shows up in its own dashboard.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ---- Mantle Sepolia (Turing Test target chain) --------------------

# Mantle Sepolia RPC — public endpoint rate-limits hard on dev loops.
# Swap in a managed RPC before the demo.
MANTLE_SEPOLIA_RPC=https://rpc.sepolia.mantle.xyz

# Deployer / agent signer EOA, hex 0x-prefixed. Fund via
# https://faucet.sepolia.mantle.xyz
DEPLOYER_PRIVATE_KEY=0x...

# ---- Mantle integration -------------------------------------------

# Mantlescan API key — https://explorer.sepolia.mantle.xyz/api-keys
MANTLESCAN_API_KEY=

# ---- Turing-Test-specific config ----------------------------------

# TODO(mantle-turing): pin Turing-track-specific config here once
# the prize prompt publishes (judge attestation endpoint, evaluator
# pubkey, scoring oracle, etc.).
TURING_TEST_TODO=
